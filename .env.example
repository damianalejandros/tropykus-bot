# ─── Tropykus Liquidation Bot — Configuración ───────────────────────────────
#
# IMPORTANTE: Nunca subas este archivo a GitHub.
# Asegurate de que .gitignore incluya ".env"
#

# Clave privada de tu wallet (sin 0x al inicio)
# Esta wallet necesita tener:
#   - RBTC para pagar gas
#   - DOC y/o USDRIF para repagar deudas y liquidar
PRIVATE_KEY=tu_clave_privada_aqui

# RPC de Rootstock — podés usar el nodo público o uno privado (Alchemy, NOWNodes, etc.)
RPC_URL=https://public-node.rsk.co

# Profit mínimo para ejecutar la liquidación (en la unidad del token)
MIN_PROFIT=50

# Intervalo de polling en milisegundos (30000 = 30 segundos)
POLL_INTERVAL_MS=30000
